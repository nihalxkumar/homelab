{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:best-practices",
    "schedule:weekly"
  ],
  "semanticCommits": true,
  "labels": [
    "dependencies",
    "renovate"
  ],
  "assignees": [
    "@neo"
  ],
  "reviewers": [
    "@neo"
  ],
  "ignorePaths": [
    "**/node_modules/**",
    ".git/**",
    ".jj/**"
  ],
  "prConcurrentLimit": 3,
  "packageRules": [
    {
      "description": "Kubernetes image patch updates - auto-merge",
      "matchDatasources": [
        "docker"
      ],
      "matchUpdateTypes": [
        "patch"
      ],
      "automerge": true,
      "automergeType": "pr",
      "automergeStrategy": "squash",
      "minimumReleaseAge": "7 days"
    },
    {
      "description": "Kubernetes image minor updates",
      "matchDatasources": [
        "docker"
      ],
      "matchUpdateTypes": [
        "minor"
      ],
      "minimumReleaseAge": "14 days"
    },
    {
      "description": "Kubernetes image major updates - monthly",
      "matchDatasources": [
        "docker"
      ],
      "matchUpdateTypes": [
        "major"
      ],
      "schedule": [
        "before 3am on the first Monday of the month"
      ],
      "minimumReleaseAge": "30 days",
      "labels": [
        "breaking-change",
        "requires-review"
      ]
    },
    {
      "description": "Python package patch updates - auto-merge",
      "matchDatasources": [
        "pip",
        "pypi"
      ],
      "matchUpdateTypes": [
        "patch"
      ],
      "automerge": true,
      "automergeType": "pr",
      "automergeStrategy": "squash",
      "minimumReleaseAge": "7 days"
    },
    {
      "description": "Python package minor updates",
      "matchDatasources": [
        "pip",
        "pypi"
      ],
      "matchUpdateTypes": [
        "minor"
      ],
      "minimumReleaseAge": "14 days"
    },
    {
      "description": "Python package major updates - monthly",
      "matchDatasources": [
        "pip",
        "pypi"
      ],
      "matchUpdateTypes": [
        "major"
      ],
      "schedule": [
        "before 3am on the first Monday of the month"
      ],
      "minimumReleaseAge": "30 days",
      "labels": [
        "breaking-change",
        "requires-review"
      ]
    },
    {
      "description": "Group minor and patch updates together",
      "matchUpdateTypes": [
        "minor",
        "patch"
      ],
      "groupName": "non-major updates",
      "groupSlug": "non-major"
    }
  ],
  "vulnerabilityAlerts": {
    "labels": [
      "security",
      "vulnerability"
    ],
    "assignees": [
      "@neo"
    ],
    "reviewers": [
      "@neo"
    ]
  }
}
